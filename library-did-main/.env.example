# Backend Configuration
NODE_ENV=development
PORT=3001
API_PREFIX=/api
LOG_LEVEL=warn

# ============================================
# Database (PostgreSQL)
# ============================================
# 로컬 개발 (Docker PostgreSQL)
DATABASE_URL=

# GCP Cloud Run (Cloud SQL Connector) - 배포 시 사용
# DATABASE_URL=postgresql://postgres:PASSWORD@localhost/smart_did?host=/cloudsql/PROJECT:REGION:INSTANCE

# ============================================
# Authentication
# ============================================
# JWT 시크릿 (생성: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=3600

# Internal API 시크릿 (Backend ↔ Worker 통신)
INTERNAL_API_SECRET=your-internal-secret-change-in-production

# Admin 계정
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ============================================
# Storage
# ============================================
# local: 로컬 파일 시스템
# gcs: Google Cloud Storage
STORAGE_TYPE=local
STORAGE_PATH=./storage/videos

# GCS 설정 (STORAGE_TYPE=gcs 시 필요)
# GCS_BUCKET=
# GCS_PUBLIC_BASE_URL=

# ============================================
# AI API Keys
# ============================================
# Gemini (스크립트/시나리오 생성)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT=120000

# OpenAI / Sora (영상 생성)
OPENAI_API_KEY=your-openai-api-key

# Veo 3.1 (선택적)
# VEO_API_KEY=your-veo-api-key
# VEO_API_ENDPOINT=https://api.veo.example.com/v1

# ============================================
# Video Generation Settings
# ============================================
VIDEO_DEFAULT_EXPIRY_DAYS=90
VIDEO_MAX_RETRIES=3
VIDEO_SCENE_DURATION=8
VIDEO_TOTAL_DURATION=24
OUTPUT_DIR=./output
TEMP_DIR=./temp
SUBTITLE_LANGUAGE=ko

# ============================================
# Redis (Cloud Memorystore)
# ============================================
# Cloud Memorystore Redis Internal IP
REDIS_HOST=
REDIS_PORT=6379

# ============================================
# Worker Configuration
# ============================================
WORKER_CONCURRENCY=2
BACKEND_URL=http://localhost:3001

# ============================================
# External APIs
# ============================================
# ALPAS 도서관 API
ALPAS_USE_MOCK=
ALPAS_API_URL=
ALPAS_API_KEY=
ALPAS_LIB_NO=
ALPAS_MANAGE_CODE=
ALPAS_NETWORK_ADAPTER_ID=

# 네이버 책 검색 API (표지 이미지, 줄거리 검색)
# https://developers.naver.com 에서 애플리케이션 등록 후 발급
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ============================================
# Frontend Configuration
# ============================================
VITE_API_URL=http://localhost:3001/api
