# ========================================
# 스마트 DID 로컬 설치 환경변수
# ========================================
# 로컬(도서관 PC)에서 Backend+Frontend 실행
# DB/영상저장은 GCP 클라우드 사용
# 영상 생성은 클라우드 Worker가 처리
# ========================================

# 서버 설정
NODE_ENV=production
PORT=3001
API_PREFIX=/api
LOG_LEVEL=info

# ========================================
# Database (GCP Cloud SQL - PostgreSQL)
# ========================================
DATABASE_URL=YOUR_DATABASE_URL_HERE

# ========================================
# Authentication
# ========================================
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=3600
INTERNAL_API_SECRET=YOUR_INTERNAL_API_SECRET_HERE

# ========================================
# Redis - 로컬에서는 사용하지 않음
# (영상 생성 큐는 클라우드 Worker가 처리)
# ========================================
REDIS_HOST=
REDIS_PORT=6379

# ========================================
# Video Storage (GCP Cloud Storage)
# ========================================
STORAGE_TYPE=gcs
STORAGE_PATH=./storage/videos
GCS_BUCKET=YOUR_GCS_BUCKET_HERE
GCS_PUBLIC_BASE_URL=YOUR_GCS_PUBLIC_URL_HERE

# ========================================
# ★★★ ALPAS 도서관 API 설정 (필수) ★★★
# ========================================
ALPAS_USE_MOCK=false
ALPAS_API_URL=YOUR_ALPAS_API_URL_HERE
ALPAS_API_KEY=YOUR_ALPAS_API_KEY_HERE
ALPAS_LIB_NO=YOUR_LIB_NO_HERE
ALPAS_MANAGE_CODE=YOUR_MANAGE_CODE_HERE
ALPAS_NETWORK_ADAPTER_ID=1

# ========================================
# Naver 책 검색 API (표지 이미지)
# ========================================
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID_HERE
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET_HERE

# ========================================
# Frontend
# ========================================
VITE_API_URL=http://localhost:3001/api

# ========================================
# 클라우드 Admin 리다이렉트
# ========================================
# 로컬에서 /admin 접속 시 클라우드 Admin으로 자동 이동
VITE_CLOUD_ADMIN_URL=YOUR_CLOUD_ADMIN_URL_HERE

# ========================================
# Admin 관리자 계정
# ========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE
